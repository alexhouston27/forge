// FORGE — Life Operating System
// Database Schema v1.0

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── USERS ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatarUrl String?
  timezone  String   @default("UTC")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Gamification
  xp    Int @default(0)
  level Int @default(1)

  // Preferences stored as JSON
  preferences Json @default("{}")

  // Relations
  goals         Goal[]
  habits        Habit[]
  habitLogs     HabitLog[]
  tasks         Task[]
  dailyPlans    DailyPlan[]
  journalEntries JournalEntry[]
  notes         Note[]
  moodLogs      MoodLog[]
  weeklyReviews WeeklyReview[]

  @@map("users")
}

// ─── GOALS ────────────────────────────────────────────────────────────────────

model Goal {
  id          String     @id @default(cuid())
  userId      String
  title       String
  description String?
  category    GoalCategory @default(PERSONAL)
  status      GoalStatus   @default(ACTIVE)
  priority    Int          @default(1) // 1-5
  targetDate  DateTime?
  progress    Float        @default(0) // 0-100
  color       String       @default("#6366f1")
  emoji       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones Milestone[]
  habits     Habit[]
  tasks      Task[]
  notes      Note[]

  @@index([userId])
  @@map("goals")
}

model Milestone {
  id          String          @id @default(cuid())
  goalId      String
  title       String
  description String?
  status      MilestoneStatus @default(PENDING)
  dueDate     DateTime?
  completedAt DateTime?
  order       Int             @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@map("milestones")
}

// ─── HABITS ───────────────────────────────────────────────────────────────────

model Habit {
  id          String        @id @default(cuid())
  userId      String
  goalId      String?
  title       String
  description String?
  category    HabitCategory @default(HEALTH)
  frequency   HabitFrequency @default(DAILY)
  trackingType HabitTrackingType @default(BINARY)
  targetValue Float?        // for quantity tracking (e.g., 8 glasses of water)
  unit        String?       // "glasses", "pages", "minutes"
  color       String        @default("#10b981")
  emoji       String?
  isActive    Boolean       @default(true)
  reminderTime String?      // "HH:MM" format

  // Streak tracking
  currentStreak Int @default(0)
  longestStreak Int @default(0)
  totalCompletions Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal Goal?     @relation(fields: [goalId], references: [id], onDelete: SetNull)
  logs HabitLog[]

  @@index([userId])
  @@map("habits")
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  userId    String
  date      DateTime @db.Date
  completed Boolean  @default(false)
  value     Float?   // for quantity tracking
  note      String?

  createdAt DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([userId, date])
  @@map("habit_logs")
}

// ─── TASKS ────────────────────────────────────────────────────────────────────

model Task {
  id          String     @id @default(cuid())
  userId      String
  goalId      String?
  dailyPlanId String?
  title       String
  description String?
  status      TaskStatus  @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  energy      EnergyLevel? // HIGH, MEDIUM, LOW — for AI scheduling
  estimatedMinutes Int?
  scheduledFor DateTime?  @db.Date
  scheduledTime String?   // "HH:MM"
  completedAt  DateTime?
  dueDate      DateTime?
  tags         String[]   @default([])
  isRecurring  Boolean    @default(false)
  recurrenceRule String?  // RRULE format

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal      Goal?      @relation(fields: [goalId], references: [id], onDelete: SetNull)
  dailyPlan DailyPlan? @relation(fields: [dailyPlanId], references: [id], onDelete: SetNull)

  @@index([userId, scheduledFor])
  @@index([userId, status])
  @@map("tasks")
}

// ─── DAILY PLANS ──────────────────────────────────────────────────────────────

model DailyPlan {
  id         String   @id @default(cuid())
  userId     String
  date       DateTime @db.Date
  mainFocus  String?
  aiGenerated Boolean @default(false)
  aiPrompt   String?
  notes      String?

  // Scores (filled in at end of day)
  productivityScore Int?  // 1-10
  energyScore       Int?  // 1-10
  moodScore         Int?  // 1-10

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks Task[]
  timeBlocks TimeBlock[]

  @@unique([userId, date])
  @@index([userId])
  @@map("daily_plans")
}

model TimeBlock {
  id          String   @id @default(cuid())
  dailyPlanId String
  title       String
  startTime   String   // "HH:MM"
  endTime     String   // "HH:MM"
  category    String?
  color       String   @default("#6366f1")
  isCompleted Boolean  @default(false)

  dailyPlan DailyPlan @relation(fields: [dailyPlanId], references: [id], onDelete: Cascade)

  @@map("time_blocks")
}

// ─── JOURNAL ──────────────────────────────────────────────────────────────────

model JournalEntry {
  id      String       @id @default(cuid())
  userId  String
  date    DateTime     @db.Date
  type    JournalType  @default(DAILY)

  // Daily review prompts
  wins         String?
  mistakes     String?
  lessons      String?
  tomorrowFocus String?
  gratitude    String?
  freeWrite    String?

  // Scores
  overallScore Int?   // 1-10

  // Mood
  mood         String?
  energy       Int?   // 1-10

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, type])
  @@index([userId])
  @@map("journal_entries")
}

model WeeklyReview {
  id        String   @id @default(cuid())
  userId    String
  weekStart DateTime @db.Date
  weekEnd   DateTime @db.Date

  movedForward  String?
  stalled       String?
  improvements  String?
  nextWeekFocus String?
  overallScore  Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId])
  @@map("weekly_reviews")
}

// ─── NOTES / IDEA VAULT ───────────────────────────────────────────────────────

model Note {
  id        String     @id @default(cuid())
  userId    String
  goalId    String?
  title     String
  content   String
  type      NoteType   @default(NOTE)
  tags      String[]   @default([])
  isPinned  Boolean    @default(false)
  isFavorite Boolean   @default(false)
  color     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal Goal? @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("notes")
}

// ─── MOOD LOGS ────────────────────────────────────────────────────────────────

model MoodLog {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  mood      Int      // 1-5 scale
  energy    Int      // 1-5 scale
  note      String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@map("mood_logs")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum GoalCategory {
  HEALTH
  CAREER
  LEARNING
  FINANCE
  RELATIONSHIPS
  CREATIVITY
  PERSONAL
  BUSINESS
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  ARCHIVED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum HabitCategory {
  HEALTH
  FITNESS
  LEARNING
  MINDFULNESS
  PRODUCTIVITY
  SOCIAL
  FINANCE
  CREATIVITY
  OTHER
}

enum HabitFrequency {
  DAILY
  WEEKLY
  WEEKDAYS
  WEEKENDS
  CUSTOM
}

enum HabitTrackingType {
  BINARY
  QUANTITY
  DURATION
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum EnergyLevel {
  LOW
  MEDIUM
  HIGH
}

enum JournalType {
  DAILY
  WEEKLY
}

enum NoteType {
  NOTE
  IDEA
  BUSINESS
  QUOTE
  RESOURCE
}
